{
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.sw.tsbuildinfo",
    "target": "ES2022",
    "lib": ["ES2022", "WebWorker"],
    "module": "ESNext",
    "types": [],
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "moduleDetection": "force",
    "noEmit": true,
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "erasableSyntaxOnly": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedSideEffectImports": true
  },
  "include": ["src/sw.ts", "src/core/heartbeatCommon.ts", "src/core/heartbeatOpenAI.ts", "src/core/heartbeatTools.ts", "src/core/heartbeat.ts", "src/core/pushSubscription.ts", "src/store/db.ts", "src/store/configStore.ts", "src/store/heartbeatStore.ts", "src/types/index.ts"]
}
